{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "eee92cf1-af83-4fe5-ba2a-7d6c4231f4c1",
  "localizationInfo": {
    "defaultLanguageTag": "en-us",
    "additionalLanguages": []
  },
  "developer": {
    "name": "Outlook Map View",
    "websiteUrl": "https://outlook-map-view.vercel.app",
    "privacyUrl": "https://outlook-map-view.vercel.app/privacy",
    "termsOfUseUrl": "https://outlook-map-view.vercel.app/terms"
  },
  "name": {
    "short": "Outlook Map View",
    "full": "Outlook Map View Add-in"
  },
  "description": {
    "short": "Visualize Outlook calendar events on a map with route previews.",
    "full": "Loads Outlook calendar events, geocodes locations, maps stops, previews routes, supports shared calendars, and summarizes daily technician travel assumptions."
  },
  "icons": {
    "outline": "assets/outline.png",
    "color": "assets/color.png"
  },
  "accentColor": "#230201",
  "validDomains": [
    "outlook-map-view.vercel.app"
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "Mailbox.ReadWrite.User",
          "type": "Delegated"
        }
      ]
    }
  },
  "extensions": [
    {
      "requirements": {
        "capabilities": [
          {
            "name": "Mailbox",
            "minVersion": "1.3"
          }
        ],
        "scopes": [
          "mail"
        ]
      },
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              {
                "name": "Mailbox",
                "minVersion": "1.3"
              }
            ]
          },
          "id": "TaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://outlook-map-view.vercel.app/taskpane.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "TaskPaneRuntimeShow",
              "type": "openPage",
              "pinnable": false,
              "view": "dashboard"
            }
          ]
        },
        {
          "id": "CommandsRuntime",
          "type": "general",
          "code": {
            "page": "https://outlook-map-view.vercel.app/commands.html",
            "script": "https://outlook-map-view.vercel.app/commands.js"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "action",
              "type": "executeFunction"
            }
          ]
        }
      ],
      "ribbons": [
        {
          "contexts": [
            "mailCompose",
            "meetingDetailsOrganizer"
          ],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "msgComposeGroup",
                  "label": "Outlook Map View",
                  "icons": [
                    {
                      "size": 16,
                      "url": "https://outlook-map-view.vercel.app/assets/icon-16.png"
                    },
                    {
                      "size": 32,
                      "url": "https://outlook-map-view.vercel.app/assets/icon-32.png"
                    },
                    {
                      "size": 80,
                      "url": "https://outlook-map-view.vercel.app/assets/icon-80.png"
                    }
                  ],
                  "controls": [
                    {
                      "id": "msgComposeOpenPaneButton",
                      "type": "button",
                      "label": "Open Map View",
                      "icons": [
                        {
                          "size": 16,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-16.png"
                        },
                        {
                          "size": 32,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-32.png"
                        },
                        {
                          "size": 80,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-80.png"
                        }
                      ],
                      "supertip": {
                        "title": "Open Map View",
                        "description": "Open the Outlook Map View task pane."
                      },
                      "actionId": "TaskPaneRuntimeShow"
                    },
                    {
                      "id": "ActionButton",
                      "type": "button",
                      "label": "Run command",
                      "icons": [
                        {
                          "size": 16,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-16.png"
                        },
                        {
                          "size": 32,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-32.png"
                        },
                        {
                          "size": 80,
                          "url": "https://outlook-map-view.vercel.app/assets/icon-80.png"
                        }
                      ],
                      "supertip": {
                        "title": "Run command",
                        "description": "Run the add-in command."
                      },
                      "actionId": "action"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}